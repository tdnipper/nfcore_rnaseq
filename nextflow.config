/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nfcore_rnaseq_denovo Nextflow config
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // ---- Required ----------------------------------------------------------------
    input                = null          // Path to samplesheet CSV
    fasta                = null          // Genome FASTA (.fa or .fa.gz)
    gtf                  = null          // Reference GTF (.gtf or .gtf.gz)
    outdir               = './results'

    // ---- Resources (machine-level caps) -----------------------------------------
    max_memory           = '202 GB'     // Available RAM on the machine
    max_cpus             = 16           // Available CPU cores on the machine

    // ---- Reference index (optional - skip HISAT2_BUILD if provided) --------------
    hisat2_index         = null          // Pre-built HISAT2 index (.tar.gz)
    hisat2_build_memory  = 200           // GB threshold: use splice sites only if available memory >= this

    // ---- UMI ---------------------------------------------------------------------
    with_umi             = true
    umitools_bc_pattern  = 'NNNNNNNNNNNN'  // 12-bp UMI
    umi_discard_read     = 0
    umitools_dedup_stats = false

    // ---- Trimming ----------------------------------------------------------------
    trim_poly_g          = true
    extra_fastp_args     = '--adapter_sequence AGATCGGAAGAGCACACGTCTGAACTCCAGTCA --adapter_sequence_r2 AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT'
    // Note: --trim_poly_g is appended below when params.trim_poly_g = true
    min_trimmed_reads    = 10000

    // ---- StringTie ---------------------------------------------------------------
    stringtie_min_length = 50
    stringtie_min_tpm    = 1

    // ---- Salmon / strandedness ---------------------------------------------------
    salmon_quant_libtype  = null         // e.g. 'ISR'; null = auto-infer from meta.strandedness
    stranded_threshold    = 0.8          // >= 80% one strand → stranded call
    unstranded_threshold  = 0.1          // <= 10% difference → unstranded call

    // ---- Skip flags --------------------------------------------------------------
    skip_fastqc           = false
    skip_fq_lint          = false        // FQ_LINT on PE reads pre- and post-trim
    skip_multiqc          = false

    // ---- Alignment extras --------------------------------------------------------
    save_unaligned        = false
    seq_center            = null
    contaminant_screening = false

    // ---- Output ------------------------------------------------------------------
    save_reference        = false
    save_trimmed_fail     = false
    publish_dir_mode      = 'symlink'  // 'symlink', 'copy', 'move', 'link', etc.
}

// Enable Podman
podman.enabled  = true
podman.registry = 'quay.io'  // resolves 'biocontainers/X' → 'quay.io/biocontainers/X'

// Work directory
workDir = './work'

// Cap requested resources at machine-level limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            def max = (params.max_memory as nextflow.util.MemoryUnit)
            if (obj.compareTo(max) == 1) return max
        } catch (all) { }
    } else if (type == 'cpus') {
        try {
            if (obj.compareTo(params.max_cpus as int) == 1) return params.max_cpus as int
        } catch (all) { }
    }
    return obj
}

// Process resource labels
process {
    executor = 'local'

    withLabel: 'process_single' {
        cpus   = { check_max(1, 'cpus') }
        memory = { check_max('6.GB' as nextflow.util.MemoryUnit, 'memory') }
    }
    withLabel: 'process_low' {
        cpus   = { check_max(2, 'cpus') }
        memory = { check_max('12.GB' as nextflow.util.MemoryUnit, 'memory') }
    }
    withLabel: 'process_medium' {
        cpus   = { check_max(6, 'cpus') }
        memory = { check_max('36.GB' as nextflow.util.MemoryUnit, 'memory') }
    }
    withLabel: 'process_high' {
        cpus   = { check_max(8, 'cpus') }
        memory = { check_max('60.GB' as nextflow.util.MemoryUnit, 'memory') }
    }
    withLabel: 'process_high_memory' {
        memory = { check_max('200.GB' as nextflow.util.MemoryUnit, 'memory') }
    }
    withLabel: 'process_long' {
        time   = '20 h'
    }

    // ---- Module-specific args ---------------------------------------------------

    // fastp: adapter trimming + optional poly-G trimming
    withName: 'FASTP' {
        ext.args = { params.trim_poly_g
            ? "${params.extra_fastp_args} --trim_poly_g"
            : params.extra_fastp_args }
        publishDir = [
            path: { "${params.outdir}/trimming" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // UMI extraction: 12-bp barcode pattern
    withName: 'UMITOOLS_EXTRACT' {
        ext.args = { "--bc-pattern=${params.umitools_bc_pattern} --log2stderr" }
    }

    // UMI deduplication
    withName: 'UMITOOLS_DEDUP' {
        ext.args = '--method=unique'
        publishDir = [
            path: { "${params.outdir}/alignment/dedup" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // HISAT2 alignment: --dta flag optimises output for StringTie
    withName: 'HISAT2_ALIGN' {
        ext.args = '--dta'
        publishDir = [
            path: { "${params.outdir}/alignment/hisat2" },
            mode: params.publish_dir_mode,
            pattern: '*.log'
        ]
    }

    // SAMTOOLS_SORT: rename output so it doesn't clash with HISAT2_ALIGN input (same meta.id)
    withName: 'SAMTOOLS_SORT' {
        ext.prefix = { "${meta.id}.sorted" }
        publishDir = [
            path: { "${params.outdir}/alignment/samtools" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // StringTie per-sample de novo assembly (no -G flag in module itself)
    withName: 'STRINGTIE_DENOVO' {
        ext.args = { "-m ${params.stringtie_min_length}" }
        publishDir = [
            path: { "${params.outdir}/stringtie/denovo" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // StringTie merge
    withName: 'STRINGTIE_MERGE' {
        ext.args = { "-m ${params.stringtie_min_length} -T ${params.stringtie_min_tpm}" }
        publishDir = [
            path: { "${params.outdir}/stringtie/merge" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // GFFREAD reference run: extract reference transcript FASTA for strandedness inference
    withName: 'GFFREAD_REF' {
        ext.args   = '-w'
        ext.prefix = 'ref_transcript'
    }

    // GFFREAD de novo run: extract de novo transcript FASTA for Salmon quantification
    withName: 'GFFREAD_DENOVO' {
        ext.args   = '-w'
        ext.prefix = 'merged_transcriptome_id'
    }

    // Salmon quantification: GC and sequence bias correction
    withName: 'SALMON_QUANT' {
        ext.args = '--gcBias --seqBias'
        publishDir = [
            path: { "${params.outdir}/salmon/quant" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // ---- publishDir-only directives ---------------------------------------------

    // FastQC on raw reads
    withName: 'FASTQC_RAW' {
        publishDir = [
            path: { "${params.outdir}/fastqc/raw" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // FastQC on trimmed reads
    withName: 'FASTQC_TRIM' {
        publishDir = [
            path: { "${params.outdir}/fastqc/trim" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Fix ref_gene_id in merged GTF
    withName: 'FIX_REF_ID' {
        publishDir = [
            path: { "${params.outdir}/stringtie/merge" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // SAMTOOLS_INDEX after sort (alignment context)
    withName: '.*:FASTQ_ALIGN_HISAT2:BAM_SORT_STATS_SAMTOOLS:SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/alignment/samtools" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // BAM stats after alignment sort
    withName: '.*:FASTQ_ALIGN_HISAT2:BAM_SORT_STATS_SAMTOOLS:BAM_STATS_SAMTOOLS:.*' {
        publishDir = [
            path: { "${params.outdir}/alignment/samtools/stats" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // SAMTOOLS_INDEX after UMI dedup
    withName: '.*:BAM_DEDUP_STATS_SAMTOOLS_UMITOOLS:SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/alignment/dedup" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // BAM stats after UMI dedup
    withName: '.*:BAM_DEDUP_STATS_SAMTOOLS_UMITOOLS:BAM_STATS_SAMTOOLS:.*' {
        publishDir = [
            path: { "${params.outdir}/alignment/dedup/stats" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // Tximeta / tximport count matrices
    withName: 'TXIMETA_TXIMPORT' {
        publishDir = [
            path: { "${params.outdir}/salmon/tximeta" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // SummarizedExperiment (gene-level)
    withName: 'SE_GENE_UNIFIED' {
        publishDir = [
            path: { "${params.outdir}/salmon/se" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // SummarizedExperiment (transcript-level)
    withName: 'SE_TRANSCRIPT_UNIFIED' {
        publishDir = [
            path: { "${params.outdir}/salmon/se" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    // MultiQC report
    withName: 'MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}

// Pipeline execution reports
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}
